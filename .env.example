# ===== 必填 =====
AMAP_API_KEY=your_amap_web_service_key
ANTHROPIC_API_KEY=sk-ant-xxxx

# Embedding（DashScope，兼容 OpenAI API）
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/restaurant_agent
JWT_SECRET=change-me-to-a-random-string

# ===== 可选 =====
REDIS_URL=redis://localhost:6379/0
AMAP_DEFAULT_CITY=北京
CLAUDE_MODEL=claude-sonnet-4-6

# Anthropic 代理（如小米代理），留空用官方
ANTHROPIC_BASE_URL=

DEFAULT_SEARCH_RADIUS=1000
MAX_SEARCH_RETRY=2
MAX_RECOMMENDATIONS=5

# 默认坐标（开发用，生产环境通过 GPS / IP 定位获取）
DEFAULT_LOCATION=116.473168,39.993015

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=text    # text（开发） | json（生产）

# LangSmith 追踪（可选，留空关闭）
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=restaurant-agent

# Sentry 错误追踪（可选，留空关闭）
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
